# Optional environment overrides.
# Prefer settings.json for persistent local settings:
#   dock-windows-codex-sender settings init

DOCK_CODEX_REPOS_CONFIG=config/repos.yaml
DOCK_CODEX_PROMPTS_CONFIG=config/prompts.yaml
DOCK_CODEX_DATA_ROOT=data
DOCK_CODEX_TRANSPORT=codex-cli
# Optional. When unset, the CLI uses `codex` from PATH or auto-detects the known local WSL launcher.
# DOCK_CODEX_BIN=codex

# If Codex CLI exists only in WSL, one working example is:
# DOCK_CODEX_BIN=wsl.exe /mnt/c/Users/amano/.codex/bin/wsl/codex
